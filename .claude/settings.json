{
  "permissions": {
    "allow": [
      "Skill(steering)",
      "Skill(steering:*)",
      "Bash(gh --version)",
      "Bash(gh auth *)",
      "Bash(gh issue *)",
      "Bash(gh extension *)",
      "Bash(NEXT_PUBLIC_API_URL=\"http://localhost:3000\" npx vitest run *)",
      "Bash(git stash *)",
      "Bash(npx tsc *)",
      "Bash(chromium-cli --session *)",
      "Bash(npx playwright *)",
      "Bash(node -e \"require.resolve\\('playwright'\\)\")",
      "Bash(curl -s http://localhost:6006/stories.json)",
      "Bash(python3 -c \"import sys,json; d=json.load\\(sys.stdin\\); [print\\(k\\) for k in d.get\\('stories',d\\).keys\\(\\) if 'time' in k.lower\\(\\)]\")"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | { read -r f; case \"$f\" in *.js|*.jsx|*.ts|*.tsx) npx eslint --fix \"$f\" ;; esac; } 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
